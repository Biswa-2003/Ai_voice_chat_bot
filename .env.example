# ── LiveKit ────────────────────────────────────────────────────────────────────
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxx
LIVEKIT_API_SECRET=your-livekit-api-secret
LIVEKIT_AGENT_NAME=voicebot
LIVEKIT_AGENT_PORT=0

# ── LLM (OpenAI or OpenRouter) ─────────────────────────────────────────────────
# OpenRouter keys (sk-or-v1-*) are auto-detected; set OPENAI_BASE_URL manually
# for other compatible providers.
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=https://openrouter.ai/api/v1

# ── Speech-to-Text (Deepgram) ──────────────────────────────────────────────────
DEEPGRAM_API_KEY=your-deepgram-api-key

# ── Text-to-Speech (ElevenLabs) ───────────────────────────────────────────────
ELEVEN_API_KEY=your-elevenlabs-api-key
# Indian English accent voice ID (find in ElevenLabs Voice Library)
TTS_EN_IN_VOICE_ID=9BWtsMINqrJLrRacOk9x
# Hindi voice ID (can be the same multilingual voice)
TTS_HI_VOICE_ID=9BWtsMINqrJLrRacOk9x

# ── Optional: Sarvam AI (native Hindi TTS/STT) ────────────────────────────────
# SARVAM_API_KEY=your-sarvam-api-key

# ── App Behaviour ─────────────────────────────────────────────────────────────
# Scenario: presale | sales | marketing
SCENARIO=presale
# Default greeting language: en | hi
DEFAULT_LANGUAGE=en
# Log directory (relative to project root)
LOG_DIR=logs
# Log verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
