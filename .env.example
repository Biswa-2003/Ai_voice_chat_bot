# ── OpenAI (or OpenRouter) ─────────────────────────────────────────────────────
# OpenRouter keys (sk-or-v1-*) are auto-detected; standard OpenAI keys also work.
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=https://openrouter.ai/api/v1   # uncomment for OpenRouter

# ── Deepgram (Speech-to-Text) ──────────────────────────────────────────────────
DEEPGRAM_API_KEY=your-deepgram-api-key

# ── TTS Provider (choose one: sarvam | elevenlabs | openai) ───────────────────
TTS_PROVIDER=sarvam

# ── Sarvam AI TTS (default — best for Indian voices) ─────────────────────────
SARVAM_API_KEY=your-sarvam-api-key
SARVAM_EN_SPEAKER=anushka   # English speaker
SARVAM_HI_SPEAKER=meera     # Hindi speaker

# ── ElevenLabs TTS (optional fallback) ────────────────────────────────────────
ELEVEN_API_KEY=your-elevenlabs-api-key
TTS_EN_IN_VOICE_ID=9BWtsMINqrJLrRacOk9x
TTS_HI_VOICE_ID=9BWtsMINqrJLrRacOk9x

# ── App Settings ───────────────────────────────────────────────────────────────
SCENARIO=presale            # presale | sales | marketing
DEFAULT_LANGUAGE=en         # en | hi
LOG_DIR=logs
LOG_LEVEL=INFO
PORT=8000
